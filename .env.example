# Contact form — Hostinger SMTP (Nodemailer)
SMTP_USER=info@muhammadkashif.net
SMTP_PASS=your_hostinger_email_password

# Admin login (/admin/login) — never commit real values
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=replace_with_a_long_random_value

ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD_SALT=replace_with_a_long_random_value
# ADMIN_PASSWORD_HASH = sha256(ADMIN_PASSWORD_SALT + your_password), hex-encoded
# Generate: node -e "console.log(require('crypto').createHash('sha256').update(process.env.SALT + process.env.PW).digest('hex'))"
ADMIN_PASSWORD_HASH=replace_with_generated_hash

# Vercel Postgres (Neon) — auto-injected when you connect storage in Vercel dashboard
# DATABASE_URL=
